# BarBoxServices Environment Configuration
# Copy this to .env and configure for your environment

# ============================================================================
# QUICK START (Local Development)
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Run: sh scripts/dev.sh
# 3. The test keys below work for local development
# ============================================================================

# Environment mode (local, test, prod)
# - local: Enables test endpoints, auto-seeds test data
# - test: Enables test endpoints, no auto-seeding
# - prod: Disables test endpoints, requires real secrets
ENV=local

# Database configuration
# - Local: Relative path creates file in project root
# - Production (Fly.io): /data/app.db on persistent volume
SQLITE_PATH=app.db

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Generate secure key for production: openssl rand -base64 64
# WARNING: Production will fail to start if key starts with "dev-"
JWT_SECRET_KEY=dev-secret-UNSAFE-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_HOURS=2

# ============================================================================
# BCRYPT PASSWORD HASHING
# ============================================================================
# Higher rounds = more secure but slower
# 12 is good default, increase for production if needed
BCRYPT_ROUNDS=12

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# For local dev, allow all origins
# For production, restrict to your domain
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ============================================================================
# DATABASE MANAGEMENT (Development Only)
# ============================================================================
# Set to true to reset database on startup (useful for clean slate)
DROP_DB_ON_STARTUP=false

# ============================================================================
# REDIS (Optional - Future Use)
# ============================================================================
REDIS_URL=

# ============================================================================
# STRIPE PAYMENT INTEGRATION
# ============================================================================
# Get from https://dashboard.stripe.com/test/apikeys (test mode)
# or https://dashboard.stripe.com/apikeys (live mode)
#
# Do NOT commit real key values (test or live) to version control.
# Use only placeholder values here; supply actual keys via environment variables.
#
# These test keys work for the BarBox Stripe account:
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_TEST_KEY_HERE

# Webhook signing secret
# - Local dev: Use Stripe CLI `stripe listen --forward-to localhost:8000/payments/webhook`
# - Production: Get from Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_YOUR_TEST_WEBHOOK_SECRET_HERE

# ============================================================================
# STRIPE PRICE IDS
# ============================================================================
# Create these in Stripe Dashboard > Products
# Each price needs metadata: {"credits": "X", "bonus_credits": "Y"}
#
# Credit Pack Pricing:
#   5 credits  = $5  (no bonus)
#  10 credits  = $10 (no bonus)
#  25 credits  = $20 (+5 bonus)
#  50 credits  = $35 (+15 bonus)
# 100 credits  = $60 (+40 bonus)
#
# These test price IDs work for the BarBox Stripe account:
STRIPE_PRICE_5_CREDITS=price_1ScHbzBaj7zkZdiEtqOc99Hq
STRIPE_PRICE_10_CREDITS=price_1ScHcPBaj7zkZdiEmu6KQynb
STRIPE_PRICE_25_CREDITS=price_1ScHcYBaj7zkZdiEiU0fkea1
STRIPE_PRICE_50_CREDITS=price_1ScHcfBaj7zkZdiERTcU7ye5
STRIPE_PRICE_100_CREDITS=price_1ScHckBaj7zkZdiEqAhFumo0

# ============================================================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================================================
# For Fly.io deployment, use fly secrets instead of .env:
#
#   fly secrets set JWT_SECRET_KEY="$(openssl rand -base64 64)"
#   fly secrets set STRIPE_SECRET_KEY="sk_live_..."
#   fly secrets set STRIPE_WEBHOOK_SECRET="whsec_..."
#   fly secrets set STRIPE_PRICE_5_CREDITS="price_..."
#   ... (all price IDs)
#
# See: docs/FLY_IO_DEPLOYMENT_GUIDE.md for complete instructions
# ============================================================================
