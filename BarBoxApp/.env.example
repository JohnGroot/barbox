# BarBox Environment Configuration
# Copy this to .env.local and configure for your deployment environment

# ============================================================================
# QUICK START
# ============================================================================
# Local Development:  Use defaults below (backend auto-starts)
# Remote Testing:     Set BARBOX_BACKEND_URL and BARBOX_TEST_MODE=1
# Production:         Set all REQUIRED variables with registered box credentials
#
# See: docs/CLIENT_CONFIGURATION.md for complete setup guide
# ============================================================================

# ============================================================================
# PRODUCTION DEPLOYMENT - REQUIRED SETUP
# ============================================================================
# For a new physical arcade box, you must:
# 1. Generate unique box UUID: uuidgen (macOS/Linux) or New-Guid (PowerShell)
# 2. Register box on backend:
#    curl -X PUT https://barbox-backend.fly.dev/box/{box-id} \
#      -H "Content-Type: application/json" \
#      -d '{"id": "{box-id}", "name": "Venue Name", "tag": "machine_tag"}'
# 3. Save API key from response (returned ONLY ONCE, cannot be retrieved)
# 4. Configure this file with box ID, API key, and backend URL
# 5. Deploy .env.local with Godot app to physical device
# ============================================================================

# REQUIRED: Unique identifier for this physical box terminal
# Production: Generate with uuidgen, register on backend first
# Development: Use seeded test box ID
# Example: BARBOX_BOX_ID=12345678-1234-1234-1234-123456789012
BARBOX_BOX_ID=00000000-0000-0000-0000-000000000001

# REQUIRED: Backend API authentication key
# Production: Obtained from box registration response (save immediately!)
# Development: Use fixed test API key below
# WARNING: Production boxes will fail authentication without valid key
# WARNING: API key is returned ONLY ONCE during registration
BARBOX_API_KEY=YOUR_DEV_BOX_API_KEY_HERE

# REQUIRED (Production): Backend service URL
# Production: https://barbox-backend.fly.dev (or your custom domain)
# Development: http://localhost:8000 (auto-started by BackendManager)
# NOTE: Use IP address (127.0.0.1) instead of "localhost" to avoid DNS delays
BARBOX_BACKEND_URL=http://localhost:8000

# OPTIONAL: Skip local backend auto-start (for testing remote backend from editor)
# Set to "1" to disable auto-start and connect directly to BARBOX_BACKEND_URL
# Useful when: testing production backend from local Godot editor
# BARBOX_TEST_MODE=1

# OPTIONAL: Human-readable box name (defaults to machine hostname)
# Format: lowercase_with_underscores
# Used for display and logging to identify this specific physical machine
# Example: BARBOX_BOX_NAME=besties_box_1
BARBOX_BOX_NAME=dev_box

# OPTIONAL: Venue name (defaults to machine hostname)
# Format: lowercase_with_underscores
# Used to group multiple boxes at same physical venue for venue-scoped data
# Mining progress and other venue-scoped data follows players across machines at same venue
# Example: BARBOX_VENUE_NAME=best_intentions
BARBOX_VENUE_NAME=dev_local

# ============================================================================
# CONFIGURATION NOTES
# ============================================================================
# File Loading Priority:
# 1. .env.local (use this for deployment - gitignored)
# 2. .env (template only - committed to repo)
# 3. System environment variables (override file settings)
#
# Required for Production:
# - BARBOX_BOX_ID (must match registered box ID)
# - BARBOX_API_KEY (from registration, cannot retrieve later)
# - BARBOX_BACKEND_URL (https://barbox-backend.fly.dev)
#
# Optional Settings:
# - BARBOX_BOX_NAME (defaults to hostname, for display/logging)
# - BARBOX_VENUE_NAME (defaults to hostname, for venue-scoped data)
# - BARBOX_TEST_MODE (set to "1" to skip local backend auto-start)
#
# Development Mode:
# - Use test box ID: 00000000-0000-0000-0000-000000000001
# - Use test API key: YOUR_DEV_BOX_API_KEY_HERE
# - Backend auto-seeds test box on startup (ENV=local)
#
# Testing Remote Backend from Editor:
# - Set BARBOX_BACKEND_URL=https://barbox-backend.fly.dev
# - Set BARBOX_TEST_MODE=1 (disables local backend auto-start)
# - Register a test box and use its credentials
#
# See docs/CLIENT_CONFIGURATION.md for complete documentation
# ============================================================================
