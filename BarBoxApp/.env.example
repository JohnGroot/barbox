# BarBox Development Environment Configuration
# Copy this to .env.local and configure your values

# Required: Unique identifier for this physical box terminal
# Generate: uuidgen (macOS/Linux) or New-Guid (PowerShell)
# Example: BARBOX_BOX_ID=12345678-1234-1234-1234-123456789012
BARBOX_BOX_ID=00000000-0000-0000-0000-000000000001

# Optional: Location identifier (defaults to machine name)
# Format: lowercase_with_underscores
# Example: BARBOX_LOCATION_ID=arcade_downtown
BARBOX_LOCATION_ID=dev_local

# Optional: Backend service URL (defaults to http://localhost:8000)
# Example: BARBOX_BACKEND_URL=http://192.168.1.100:8000
BARBOX_BACKEND_URL=http://localhost:8000
